# Run output (sessions, artifacts, logs) — never tracked, except curated
# cross-machine baseline snapshots under results/baselines/ (see
# results/baselines/README.md and docs/DESIGN.md D24).
results/*
!results/baselines/

# Per-machine site config (paths); commit site.example.yaml instead
configs/site.local.yaml

# Built compressor artifacts inside submodules
external/**/build/
external/**/install/

# Downloaded datasets
data/
datasets/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# Editor / OS
.vscode/
.DS_Store
